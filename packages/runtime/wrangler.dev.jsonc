{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "mongolgpt-runtime-dev",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-18",
  "compatibility_flags": ["nodejs_compat"],
  "routes": [
    {
      "pattern": "runtime.dev.mgpt.mn",
      "custom_domain": true
    }
  ],
  "vars": {
    "MONGOLGPT_APP_ORIGIN": "https://app.dev.mgpt.mn",
    "MONGOLGPT_CONSOLE_ORIGIN": "https://dev.mgpt.mn",
    "MONGOLGPT_RUNTIME_VERSION": "0.1.1",
    "STAGE": "dev"
  },
  "secrets": {
    "required": ["MONGOLGPT_RUNTIME_SECRET"]
  },
  "ratelimits": [
    {
      "name": "MONGOLGPT_RUNTIME_BURST_LIMITER",
      "namespace_id": "206071801",
      "simple": {
        "limit": 60,
        "period": 10
      }
    },
    {
      "name": "MONGOLGPT_RUNTIME_RATE_LIMITER",
      "namespace_id": "206071802",
      "simple": {
        "limit": 300,
        "period": 60
      }
    }
  ],
  "containers": [
    {
      "class_name": "MongolGPTSandbox",
      "image": "./Dockerfile",
      "instance_type": "basic",
      "max_instances": 5
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "name": "Sandbox",
        "class_name": "MongolGPTSandbox"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["MongolGPTSandbox"]
    }
  ]
}
