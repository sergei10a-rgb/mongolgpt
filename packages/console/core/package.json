{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@mongolgpt/console-core",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-sts": "3.782.0",
    "@jsx-email/render": "1.1.1",
    "@mongolgpt/console-mail": "workspace:*",
    "@mongolgpt/console-resource": "workspace:*",
    "aws4fetch": "1.0.20",
    "drizzle-orm": "catalog:",
    "postgres": "3.4.7",
    "stripe": "18.0.0",
    "ulid": "catalog:",
    "zod": "catalog:"
  },
  "exports": {
    "./*.js": "./src/*.ts",
    "./*": "./src/*"
  },
  "scripts": {
    "db": "drizzle-kit generate --config=drizzle.config.ts",
    "db-d1-generate": "drizzle-kit generate --config=drizzle.d1.config.ts",
    "db-dev": "sst shell --stage dev -- drizzle-kit migrate --config=drizzle.remote.config.ts",
    "db-prod": "sst shell --stage production -- drizzle-kit migrate --config=drizzle.remote.config.ts",
    "db-studio": "sst shell -- drizzle-kit studio --config=drizzle.remote.config.ts",
    "update-models": "script/update-models.ts",
    "promote-models-to-dev": "script/promote-models.ts dev",
    "promote-models-to-prod": "script/promote-models.ts production",
    "pull-models-from-dev": "script/pull-models.ts dev",
    "pull-models-from-prod": "script/pull-models.ts production",
    "update-limits": "script/update-limits.ts",
    "promote-limits-to-dev": "script/promote-limits.ts dev",
    "promote-limits-to-prod": "script/promote-limits.ts production",
    "test": "bun test test",
    "typecheck": "tsgo --noEmit"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "catalog:",
    "@tsconfig/node22": "22.0.2",
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "drizzle-kit": "catalog:",
    "typescript": "catalog:",
    "@typescript/native-preview": "catalog:"
  }
}
