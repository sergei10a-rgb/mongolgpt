# MongolGPT-ийн эзэмшдэг production домэйн авсны дараа эдгээрийг тохируулна.
MONGOLGPT_DOMAIN=your-domain.example
MONGOLGPT_PUBLIC_URL=https://your-domain.example
MONGOLGPT_CONSOLE_URL=https://your-domain.example
MONGOLGPT_AUTH_URL=https://auth.your-domain.example
MONGOLGPT_API_URL=https://api.your-domain.example
MONGOLGPT_WEB_UI_URL=https://app.your-domain.example
MONGOLGPT_DOCS_URL=https://docs.your-domain.example/docs
MONGOLGPT_SHARE_URL=https://share.your-domain.example
MONGOLGPT_GO_URL=https://your-domain.example/zen/go
MONGOLGPT_SUPPORT_URL=https://github.com/sergei10a-rgb/mongolgpt/issues
MONGOLGPT_COMMUNITY_URL=https://github.com/sergei10a-rgb/mongolgpt/discussions
MONGOLGPT_CONTACT_EMAIL=
MONGOLGPT_ENABLE_HOSTED_SERVICES=false
# Cloudflare D1 live stats-ийг hosted deploy дээр асаах бол true болгоно.
MONGOLGPT_ENABLE_ANALYTICS=false
MONGOLGPT_ENABLE_BUSINESS_INTEGRATIONS=false
MONGOLGPT_ENABLE_LEGACY_STRIPE=false
MONGOLGPT_ENABLE_MONITORING=false
MONGOLGPT_ENABLE_SHARE_SERVICE=false
MONGOLGPT_ENABLE_SYNC_SERVICE=false

# Cloudflare deployment-ийн утгууд. Эдгээрийг Git-д хэзээ ч commit хийхгүй.
CLOUDFLARE_DEFAULT_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Production deploy хийхдээ DEPLOY your-domain.example гэж яг бичиж баталгаажуулна.
MONGOLGPT_PRODUCTION_CONFIRMATION=

MONGOLGPT_AUTH_EMAIL_DOMAINS=

# Hosted BYOK vault-ийн тогтвортой master key. GitHub secret-ийг workflow энэ SST нэр рүү хөрвүүлнэ.
SST_SECRET_ByokCredentialsKeyV1=

# Hosted auth болон Free Auto runtime. GitHub Environment утгуудыг workflow SST_SECRET_* хэлбэрт хөрвүүлнэ.
GITHUB_CLIENT_ID_CONSOLE=
GITHUB_CLIENT_SECRET_CONSOLE=
GOOGLE_CLIENT_ID=
ZEN_SESSION_SECRET=
ZEN_MODELS1=
# JSON урт бол ZEN_MODELS2 ... ZEN_MODELS30 optional үргэлжлэл ашиглана.

# Browser bundle-д орох public утгууд. Нууц түлхүүр энд бүү байрлуул.
VITE_MONGOLGPT_PUBLIC_URL=https://your-domain.example
VITE_MONGOLGPT_DOCS_URL=https://docs.your-domain.example/docs
VITE_MONGOLGPT_SUPPORT_URL=https://github.com/sergei10a-rgb/mongolgpt/issues
VITE_MONGOLGPT_COMMUNITY_URL=https://github.com/sergei10a-rgb/mongolgpt/discussions
VITE_MONGOLGPT_CHANGELOG_URL=https://your-domain.example/changelog.json
